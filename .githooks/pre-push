#!/usr/bin/env bash
# Pre-push guard: block pushes that would fail CI's formatting/style or
# changed-source clang-tidy checks.
#
# - Check-only: never modifies files (no clang-format -i, no churn).
# - Changed-only: fast for source edits; header-only C/C++ edits run full
#   clang-tidy because headers are not compile database translation units.
# - Skips gracefully when tools are absent, so it can never block a push on a
#   bare machine. Bypass in an emergency: git push --no-verify
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -f "$repo_root/lint.ps1" ] || exit 0

pwsh_bin=""
for c in pwsh pwsh.exe powershell.exe powershell; do
  if command -v "$c" >/dev/null 2>&1; then pwsh_bin="$c"; break; fi
done
if [ -z "$pwsh_bin" ]; then
  echo "pre-push: PowerShell not found; skipping format check." >&2
  exit 0
fi

if ! command -v clang-format >/dev/null 2>&1 || ! command -v dotnet >/dev/null 2>&1; then
  echo "pre-push: clang-format/dotnet not found; skipping format check (install LLVM + .NET to enable)." >&2
  exit 0
fi

full_lint_available=1
for c in clang-tidy clang-apply-replacements cmake ninja python; do
  if ! command -v "$c" >/dev/null 2>&1; then
    full_lint_available=0
    break
  fi
done

lint_args=(-Check -ChangedOnly)
lint_label="formatting and changed-source clang-tidy"
if [ "$full_lint_available" -ne 1 ]; then
  echo "pre-push: clang-tidy/CMake/Ninja/Python not found; falling back to format-only check." >&2
  lint_args=(-FormatOnly -Check -ChangedOnly)
  lint_label="formatting"
fi

echo "pre-push: checking $lint_label (lint.ps1 ${lint_args[*]})..." >&2
"$pwsh_bin" -NoProfile -ExecutionPolicy Bypass -File "$repo_root/lint.ps1" "${lint_args[@]}"
if [ "$?" -ne 0 ]; then
  {
    echo ""
    echo "pre-push BLOCKED: changed files would fail CI's lint job."
    echo "  Fix format:  pwsh ./lint.ps1 -FormatOnly -ChangedOnly"
    echo "  Check again: pwsh ./lint.ps1 -Check -ChangedOnly"
    echo "  Then:        git add -u && git commit and push again."
    echo "  Bypass:      git push --no-verify"
  } >&2
  exit 1
fi

echo "pre-push: lint check passed." >&2
exit 0
