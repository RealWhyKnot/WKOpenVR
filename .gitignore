.code

# CMake build tree.
[bB]in
[bB]uild
/build/

# .NET intermediate build outputs (modules/facetracking/src/host/ projects).
# Generated by dotnet build / dotnet publish; never committed.
[oO]bj/

# Per-session local-build counter (regenerated each build).
/build/local_build_state.json

# Per-module BuildStamp.h is regenerated by build.ps1 each release; the
# CMakeLists.txt fallback writes a dev placeholder when missing. Tracking
# the regenerated file creates spurious diffs after every build.
modules/calibration/src/overlay/BuildStamp.h
modules/facetracking/src/overlay/BuildStamp.h
modules/inputhealth/src/overlay/BuildStamp.h
modules/oscrouter/src/overlay/BuildStamp.h
modules/smoothing/src/overlay/BuildStamp.h
modules/captions/src/overlay/BuildStamp.h
core/src/common/BuildChannel.h

# Scratch state from build.ps1 / quick.ps1 / test.ps1.
/.test.*
/.quick.*

# Release artifacts produced by build.ps1 -Release. Generated, not committed.
/release/

# Local command logs and scratch state.
/*.log
/.local/

# Changelog stash captured by .github/workflows/release.yml during a CI build.
/.changelog-stash/

# Local tooling state.
.claude/
CLAUDE.md
.claude.local.json
.anthropic/

# Build version stamp generated by build.ps1.
version.txt
