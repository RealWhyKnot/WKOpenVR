{
  "name": "WKOpenVR Dashboard Input - Index Knuckles",
  "controller_type": "knuckles",
  "bindings": {
    "/actions/dashboardinput_toggle": {
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/dashboardinput_toggle/in/toggle"
            }
          },
          "mode": "button",
          "path": "/user/hand/left/input/system"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/dashboardinput_toggle/in/toggle"
            }
          },
          "mode": "button",
          "path": "/user/hand/right/input/system"
        }
      ]
    },
    "/actions/dashboardinput_pointer": {
      "poses": [
        {
          "output": "/actions/dashboardinput_pointer/in/pointer",
          "path": "/user/hand/left/pose/tip"
        },
        {
          "output": "/actions/dashboardinput_pointer/in/pointer",
          "path": "/user/hand/right/pose/tip"
        }
      ],
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/dashboardinput_pointer/in/left_click"
            }
          },
          "mode": "button",
          "parameters": {
            "click_activate_threshold": "0.65",
            "click_deactivate_threshold": "0.60"
          },
          "path": "/user/hand/left/input/trigger"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/dashboardinput_pointer/in/left_click"
            }
          },
          "mode": "button",
          "parameters": {
            "click_activate_threshold": "0.65",
            "click_deactivate_threshold": "0.60"
          },
          "path": "/user/hand/right/input/trigger"
        },
        {
          "inputs": {
            "scroll": {
              "output": "/actions/dashboardinput_pointer/in/scroll"
            }
          },
          "mode": "scroll",
          "parameters": {
            "scroll_mode": "discrete"
          },
          "path": "/user/hand/left/input/thumbstick"
        },
        {
          "inputs": {
            "scroll": {
              "output": "/actions/dashboardinput_pointer/in/scroll"
            }
          },
          "mode": "scroll",
          "parameters": {
            "scroll_mode": "discrete"
          },
          "path": "/user/hand/right/input/thumbstick"
        },
        {
          "inputs": {
            "scroll": {
              "output": "/actions/dashboardinput_pointer/in/scroll"
            }
          },
          "mode": "scroll",
          "parameters": {
            "discrete_scroll_trackpad_accumthreshold_onmove": "0.28",
            "discrete_scroll_trackpad_accumthreshold_onreversal": "0.84",
            "discrete_scroll_trackpad_accumthreshold_ontouch": "0.78",
            "scroll_mode": "discrete"
          },
          "path": "/user/hand/left/input/trackpad"
        },
        {
          "inputs": {
            "scroll": {
              "output": "/actions/dashboardinput_pointer/in/scroll"
            }
          },
          "mode": "scroll",
          "parameters": {
            "discrete_scroll_trackpad_accumthreshold_onmove": "0.28",
            "discrete_scroll_trackpad_accumthreshold_onreversal": "0.84",
            "discrete_scroll_trackpad_accumthreshold_ontouch": "0.78",
            "scroll_mode": "discrete"
          },
          "path": "/user/hand/right/input/trackpad"
        }
      ]
    }
  }
}
