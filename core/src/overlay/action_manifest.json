{
  "default_bindings": [
    {
      "controller_type": "knuckles",
      "binding_url": "bindings_dashboardinput_knuckles.json"
    },
    {
      "controller_type": "oculus_touch",
      "binding_url": "bindings_dashboardinput_touch.json"
    },
    {
      "controller_type": "vive_controller",
      "binding_url": "bindings_dashboardinput_vive.json"
    },
    {
      "controller_type": "generic",
      "binding_url": "bindings_dashboardinput_generic.json"
    }
  ],
  "actions": [
    {
      "name": "/actions/dashboardinput_toggle/in/toggle",
      "type": "boolean",
      "requirement": "mandatory"
    },
    {
      "name": "/actions/dashboardinput_pointer/in/pointer",
      "type": "pose",
      "requirement": "mandatory"
    },
    {
      "name": "/actions/dashboardinput_pointer/in/left_click",
      "type": "boolean",
      "requirement": "mandatory"
    },
    {
      "name": "/actions/dashboardinput_pointer/in/scroll",
      "type": "vector2",
      "requirement": "optional"
    }
  ],
  "action_sets": [
    {
      "name": "/actions/dashboardinput_toggle",
      "usage": "leftright"
    },
    {
      "name": "/actions/dashboardinput_pointer",
      "usage": "leftright"
    }
  ],
  "localization": [
    {
      "language_tag": "en_US",
      "/actions/dashboardinput_toggle": "WKOpenVR Dashboard Input",
      "/actions/dashboardinput_toggle/in/toggle": "Toggle WKOpenVR",
      "/actions/dashboardinput_pointer": "WKOpenVR Dashboard Pointer",
      "/actions/dashboardinput_pointer/in/pointer": "Pointer",
      "/actions/dashboardinput_pointer/in/left_click": "Click",
      "/actions/dashboardinput_pointer/in/scroll": "Scroll"
    }
  ]
}
